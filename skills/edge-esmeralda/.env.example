# Required for calendar (events, RSVPs, venues) — issued at the EdgeOS portal under /portal/api-keys
EDGEOS_API_KEY=            # Personal access token, eos_live_...

# Required for attendee directory search — separate token from the citizen portal
EDGEOS_BEARER_TOKEN=       # EdgeOS citizen portal JWT

# Required for the Index Network discovery layer (§3) — generated at index.network/agents
INDEX_API_KEY=             # Index Network API key, ix_...
